title: Coalition Affairs
new-page: true
is-card: true
tags: govt_affairs
on-arrival: month_actions += 1; coalition_affairs_timer = 5
view-if: cs_in_government = 1 and coalition_dissent >= 1 and coalition_affairs_timer = 0 and (in_unity_coalition or in_bourgeisbloc_coalition)
